---
interface Experience {
  title: string;
  description: string;
  note: string;
}

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<section class="alta-section" id="experiences" aria-labelledby="experiences-title">
  <div class="alta-shell">
    <header class="alta-section__header">
      <p class="alta-kicker">Autour du lieu</p>
      <h2 id="experiences-title">Des expériences simples, ancrées dans le territoire</h2>
      <p>
        Maison Alta ne cherche pas à tout remplir. Le séjour s'organise autour
        de quelques rythmes lisibles : marcher, manger, visiter, se reposer.
      </p>
    </header>

    <div class="alta-experience-grid">
      {experiences.map((experience, index) => (
        <article class="alta-experience-card">
          <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
          <h3>{experience.title}</h3>
          <p>{experience.description}</p>
          <small>{experience.note}</small>
        </article>
      ))}
    </div>
  </div>
</section>
