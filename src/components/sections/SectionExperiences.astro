---
interface Experience {
  title: string;
  description: string;
  note: string;
}

interface Props {
  kicker: string;
  title: string;
  intro: string;
  experiences: ReadonlyArray<Experience>;
}

const { kicker, title, intro, experiences } = Astro.props;
---

<section class="alta-section" id="experiences" aria-labelledby="experiences-title">
  <div class="alta-shell">
    <header class="alta-section__header">
      <p class="alta-kicker">{kicker}</p>
      <h2 id="experiences-title">{title}</h2>
      <p>{intro}</p>
    </header>

    <div class="alta-experience-grid">
      {experiences.map((experience, index) => (
        <article class="alta-experience-card u-card-lift-subtle">
          <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
          <h3>{experience.title}</h3>
          <p>{experience.description}</p>
          <small>{experience.note}</small>
        </article>
      ))}
    </div>
  </div>
</section>
