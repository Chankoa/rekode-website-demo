---
interface InfoGroup {
  title: string;
  items: string[];
}

interface Props {
  groups: InfoGroup[];
}

const { groups } = Astro.props;
---

<section class="alta-section alta-section--muted" id="infos" aria-labelledby="infos-title">
  <div class="alta-shell">
    <header class="alta-section__header">
      <p class="alta-kicker">Infos pratiques</p>
      <h2 id="infos-title">Préparer votre séjour</h2>
      <p>
        Les informations essentielles restent visibles, sans transformer la page
        en brochure exhaustive.
      </p>
    </header>

    <div class="alta-info-grid">
      {groups.map((group) => (
        <article class="alta-info-card">
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
