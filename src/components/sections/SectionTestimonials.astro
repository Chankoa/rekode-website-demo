---
interface Testimonial {
  quote: string;
  author: string;
  stay: string;
}

interface Props {
  kicker: string;
  title: string;
  testimonials: ReadonlyArray<Testimonial>;
}

const { kicker, title, testimonials } = Astro.props;
---

<section class="alta-section" aria-labelledby="avis-title">
  <div class="alta-shell">
    <header class="alta-section__header">
      <p class="alta-kicker">{kicker}</p>
      <h2 id="avis-title">{title}</h2>
    </header>

    <div class="alta-testimonial-grid">
      {testimonials.map((testimonial) => (
        <figure class="alta-testimonial-card">
          <blockquote>
            "{testimonial.quote}"
          </blockquote>
          <figcaption>
            <strong>{testimonial.author}</strong>
            <span>{testimonial.stay}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
