---
import Layout from "../components/layout/Layout.astro";
import HospitalityHero from "../components/sections/HospitalityHero.astro";
import SectionPlace from "../components/sections/SectionPlace.astro";
import SectionRooms from "../components/sections/SectionRooms.astro";
import SectionExperiences from "../components/sections/SectionExperiences.astro";
import SectionGallery from "../components/sections/SectionGallery.astro";
import SectionPracticalInfo from "../components/sections/SectionPracticalInfo.astro";
import SectionTestimonials from "../components/sections/SectionTestimonials.astro";
import SectionFaq from "../components/sections/SectionFaq.astro";
import SectionFinalCta from "../components/sections/SectionFinalCta.astro";
import { homePageContent } from "../data/page-content";
import { siteConfig } from "../data/site-config";
import { roomDetails } from "../data/rooms";

const rooms = roomDetails.map((room) => ({
  title: room.title,
  capacity: room.capacity,
  ambiance: room.shortAmbiance,
  detailHref: `/chambres/${room.slug}`,
  imageSrc: room.imageSrc,
  imageAlt: room.imageAlt,
}));
---

<Layout
  title={homePageContent.hero.eyebrow}
  description={siteConfig.meta.description}
>
  <HospitalityHero
    eyebrow={homePageContent.hero.eyebrow}
    title={siteConfig.name}
    subtitle={homePageContent.hero.subtitle}
    primaryCtaLabel={homePageContent.hero.primaryCtaLabel}
    primaryCtaHref={homePageContent.hero.primaryCtaHref}
    secondaryCtaLabel={homePageContent.hero.secondaryCtaLabel}
    secondaryCtaHref={homePageContent.hero.secondaryCtaHref}
    imageSrc={homePageContent.hero.imageSrc}
    imageAlt={homePageContent.hero.imageAlt}
  />

  <SectionPlace
    kicker={homePageContent.place.kicker}
    title={homePageContent.place.title}
    intro={homePageContent.place.intro}
    imageSrc={homePageContent.place.imageSrc}
    imageAlt={homePageContent.place.imageAlt}
    caption={homePageContent.place.caption}
    points={homePageContent.place.points}
  />

  <SectionRooms
    kicker={homePageContent.rooms.kicker}
    title={homePageContent.rooms.title}
    intro={homePageContent.rooms.intro}
    detailLabel={homePageContent.rooms.detailLabel}
    rooms={rooms}
  />

  <SectionExperiences
    kicker={homePageContent.experiences.kicker}
    title={homePageContent.experiences.title}
    intro={homePageContent.experiences.intro}
    experiences={homePageContent.experiences.items}
  />

  <SectionGallery
    kicker={homePageContent.gallery.kicker}
    title={homePageContent.gallery.title}
    items={homePageContent.gallery.items}
  />

  <SectionPracticalInfo
    kicker={homePageContent.practicalInfo.kicker}
    title={homePageContent.practicalInfo.title}
    intro={homePageContent.practicalInfo.intro}
    groups={homePageContent.practicalInfo.groups}
  />

  <SectionTestimonials
    kicker={homePageContent.testimonials.kicker}
    title={homePageContent.testimonials.title}
    testimonials={homePageContent.testimonials.items}
  />

  <SectionFaq
    kicker={homePageContent.faq.kicker}
    title={homePageContent.faq.title}
    items={homePageContent.faq.items}
  />

  <SectionFinalCta
    kicker={siteConfig.name}
    title={homePageContent.finalCta.title}
    text={homePageContent.finalCta.text}
    emailHref={`mailto:${siteConfig.contact.email}`}
    availabilityHref="#infos"
    primaryLabel={homePageContent.finalCta.primaryLabel}
    secondaryLabel={homePageContent.finalCta.secondaryLabel}
  />
</Layout>
